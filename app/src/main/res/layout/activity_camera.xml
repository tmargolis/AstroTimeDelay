<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Display for delayed video + overlay -->
    <ImageView
        android:id="@+id/displayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter" />

    <!-- Mode indicator label -->
    <TextView
        android:id="@+id/modeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_margin="16dp"
        android:text="Mode"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#80000000" />

    <!-- EMA ghost-stack mini-view (layout set programmatically; placed here so queuingLabel renders on top) -->
    <ImageView
        android:id="@+id/stackView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:scaleType="fitXY"
        android:background="#000000" />

    <!-- Large centered label shown while buffer is filling (on top of stackView) -->
    <TextView
        android:id="@+id/queuingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="QUEUEING"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:letterSpacing="0.2"
        android:alpha="0.7"
        android:visibility="gone" />

    <!-- Mode name + delay label, very bottom left -->
    <TextView
        android:id="@+id/modeNameLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="0dp"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:padding="8dp"
        android:background="#80000000" />

    <!-- Mode indicator label in bottom right (bottom margin adjusted in code to sit above stackView) -->
    <TextView
        android:id="@+id/modeIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:text="Moon"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:background="#80000000" />

</FrameLayout>
