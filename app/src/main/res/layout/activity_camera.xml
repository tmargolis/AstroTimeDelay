<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Display for delayed video + overlay -->
    <ImageView
        android:id="@+id/displayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter" />

    <!-- Mode indicator label -->
    <TextView
        android:id="@+id/modeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_margin="16dp"
        android:text="Mode"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:padding="12dp"
        android:background="#80000000" />

    <!-- EMA ghost-stack mini-view (layout set programmatically; placed here so queuingLabel renders on top) -->
    <ImageView
        android:id="@+id/stackView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:scaleType="fitXY"
        android:background="@drawable/ghost_preview_border"
        android:padding="1dp" />

    <!-- Celestial object overlay shown during QUEUEING on top of the fullscreen ghost.
         Hidden during DELAY mode (the overlay is then composited into displayView by renderFrame).
         Size and scaleType are set in code per mode. -->
    <ImageView
        android:id="@+id/countdownOverlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:alpha="0.5"
        android:visibility="gone" />

    <!-- Movie barcode: full-width strip at the bottom showing one vertical slit per stored frame.
         Oldest frame on left, most recent on right. Height overridden in code to match miniH.
         During QUEUEING fills left→right; during PLAYBACK scrolls left as new frames arrive. -->
    <ImageView
        android:id="@+id/barcodeView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:scaleType="fitXY" />

    <!-- Separate layer for fixed tick markers over the barcode strip.
         Prevents ticks from scrolling or being drawn into the movie barcode history. -->
    <ImageView
        android:id="@+id/tickView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:scaleType="fitXY" />

    <!-- Large centered label shown while buffer is filling (on top of stackView) -->
    <TextView
        android:id="@+id/queuingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="QUEUEING"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:letterSpacing="0.2"
        android:alpha="0.7"
        android:visibility="gone" />

    <!-- Bottom-left label row: mode name + delay, then countdown/timestamp to its right.
         Both share a horizontal LinearLayout so the timer always sits flush right of the name.
         Bottom margin is adjusted in code to lift the row above the barcode strip. -->
    <LinearLayout
        android:id="@+id/bottomLabelRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="0dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/modeNameLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:background="#80000000" />

        <!-- Countdown / timestamp — sits immediately right of the mode name label -->
        <TextView
            android:id="@+id/modeIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Moon"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:fontFamily="monospace"
            android:background="#80000000" />

    </LinearLayout>

</FrameLayout>
