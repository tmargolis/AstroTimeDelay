<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Main display area for delayed video or ghost overlay -->
    <ImageView
        android:id="@+id/mainView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitStart" />

    <!-- Celestial object image overlay shown during QUEUEING on top of the fullscreen ghost.
         Hidden during DELAY mode (the overlay is then composited into displayView by renderFrame).
         Size and scaleType are set in code per mode. -->
    <ImageView
        android:id="@+id/countdownOverlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        android:visibility="gone" />

    <!-- Movie barcode: full-width strip at the bottom showing one vertical slit per stored frame.
         Oldest frame on left, most recent on right. Height overridden in code to match miniH.
         During QUEUEING fills left→right; during PLAYBACK scrolls left as new frames arrive. -->
    <ImageView
        android:id="@+id/barcodeView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:scaleType="fitXY" />

    <!-- Separate layer for fixed tick markers over the barcode strip.
         Prevents ticks from scrolling or being drawn into the movie barcode history. -->
    <ImageView
        android:id="@+id/tickView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="bottom"
        android:scaleType="fitXY" />

    <!-- EMA ghost-stack mini-view: shown in bottom-right corner during PLAYBACK only.
         Layout dimensions set programmatically. Sits above barcode/ticks in z-order. -->
    <ImageView
        android:id="@+id/stackView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_gravity="bottom|end"
        android:scaleType="fitXY"
        android:background="@drawable/ghost_preview_border"
        android:padding="1dp"
        android:visibility="gone" />

    <!-- QUEUEING label anchored just above the barcode strip; bottom margin set in code. -->
    <TextView
        android:id="@+id/queuingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:text="QUEUEING"
        android:textColor="#FFFFFF"
        android:textSize="48sp"
        android:letterSpacing="0.2"
        android:alpha="0.7"
        android:visibility="gone" />

    <!-- Mode name at top-center of screen, above the celestial overlay. -->
    <TextView
        android:id="@+id/modeNameLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:padding="8dp"
        android:fontFamily="monospace"
        android:background="@drawable/label_background" />

    <!-- Bottom-left label: countdown/timestamp.
         Bottom margin is adjusted in code to lift the row above the barcode strip. -->
    <LinearLayout
        android:id="@+id/bottomLabelRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="0dp"
        android:layout_marginBottom="0dp"
        android:orientation="horizontal">

        <!-- Countdown / timestamp -->
        <TextView
            android:id="@+id/modeIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:padding="8dp"
            android:fontFamily="monospace"
            android:background="@drawable/mode_indicator_background" />

    </LinearLayout>

</FrameLayout>
